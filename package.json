{
  "name": "symphifony",
  "version": "0.1.11",
  "private": false,
  "type": "module",
  "description": "Filesystem-backed local Symphifony orchestrator with a TypeScript CLI, MCP mode, and multi-agent Codex or Claude workflows.",
  "bin": {
    "symphifony": "./bin/symphifony.js"
  },
  "scripts": {
    "start": "node ./bin/symphifony.js",
    "dev": "node ./bin/symphifony.js --port 4000 & vite --config src/dashboard/vite.config.js & wait",
    "dev:api": "node ./bin/symphifony.js --port 4000",
    "dev:ui": "vite --config src/dashboard/vite.config.js",
    "build:ui": "vite build --config src/dashboard/vite.config.js",
    "mcp": "node ./bin/symphifony.js mcp"
  },
  "files": [
    "bin/",
    "src/",
    "WORKFLOW.md",
    "README.md",
    "SYMPHIFONY.md",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forattini-dev/symphifony.git"
  },
  "bugs": {
    "url": "https://github.com/forattini-dev/symphifony/issues"
  },
  "homepage": "https://github.com/forattini-dev/symphifony#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=23"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "cli-args-parser": "^1.0.6",
    "lucide-react": "^0.577.0",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "raffel": "^1.0.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "s3db.js": "21.2.10",
    "tsx": "^4.21.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.0"
  }
}
